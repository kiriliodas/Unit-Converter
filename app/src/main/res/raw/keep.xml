<?xml version="1.0" encoding="utf-8"?>
<!--
  Tell the release resource shrinker to KEEP all launcher-icon resources.

  The manifest references @mipmap/ic_launcher, which on API 26+ resolves to the
  adaptive-icon XML. The shrinker doesn't always trace the per-density PNG
  fallbacks (used on API 24–25) or the adaptive icon's drawable layers as
  reachable, so it can strip them from the release APK — which makes the launcher
  fall back to the default Android icon. Keeping them explicitly fixes that.
-->
<resources xmlns:tools="http://schemas.android.com/tools"
    tools:keep="
        @mipmap/ic_launcher,
        @mipmap/ic_launcher_round,
        @mipmap/*ic_launcher*,
        @drawable/ic_launcher_background,
        @drawable/ic_launcher_foreground"
    tools:shrinkMode="safe" />
